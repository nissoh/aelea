{
  "name": "monorepo",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "sherif": "sherif",
    "sherif:fix": "sherif --fix",
    "biome:check": "biome check",
    "biome:check:fix": "biome check --fix",
    "tsc:check": "bun run --filter '*' tsc:check",
    "lint": "bun run biome:check && bun run tsc:check",
    "aelea:build": "cd aelea && bun run build",
    "website:build": "cd website && bun run build",
    "build": "bun run aelea:build && bun run website:build"
  },
  "workspaces": [
    "aelea",
    "website"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@typescript/native-preview": "^7.0.0-dev.20260419.1",
    "sherif": "1.11.1"
  },
  "author": "Nissan Hanina <nissanhanina@gmail.com>",
  "private": true,
  "packageManager": "bun@1.3.13"
}
