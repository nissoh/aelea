{
  "npm.packageManager": "bun",
  "workbench.editor.enablePreview": true,
  "workbench.editor.enablePreviewFromQuickOpen": true,
  "npm.scriptRunner": "bun",
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bun.lock": true,
    "**/dist": true
  },
  "js/ts.experimental.useTsgo": true,
  "editor.tabSize": 2
}