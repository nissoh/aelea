{
  "extends": "../tsconfig.base.json",
  "include": [
    "src"
  ],
  "compilerOptions": {
    "lib": [
      "ESNext",
      "DOM"
    ],
    "outDir": "dist/esm",
    "rootDir": "./src",
    "declaration": true,
    "declarationDir": "dist/types",
    "baseUrl": ".",
    "paths": {
      "@/ui": [
        "src/ui/index.ts"
      ],
      "@/stream": [
        "src/stream/index.ts"
      ],
      "@/stream-extended": [
        "src/stream-extended/index.ts"
      ]
    }
  }
}