{
  "extends": "../tsconfig.base.json",
  "include": ["src"],
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "outDir": "dist/esm",
    "rootDir": "./src",
    "declaration": true,
    "declarationDir": "dist/types"
    // Intentionally no `paths` aliases: tsc does not rewrite them at emit,
    // so `@/stream` etc. would ship to dist as-is and break bundlers
    // consuming aelea. Use relative imports across `src/`.
  }
}
