{
  "name": "aelea",
  "version": "4.1.0",
  "type": "module",
  "scripts": {
    "build": "bun run build:clean && tsgo -b",
    "build:clean": "rm -rf dist",
    "tsc:check": "tsgo -p tsconfig.json --noEmit",
    "test": "bun test test/",
    "bench:combinators": "bun run benchmark/combinators.ts",
    "bench:characteristics": "bun run benchmark/combinator-characteristics.ts",
    "bench:takumi": "bun run benchmark/og-takumi.ts",
    "bench:headless": "bun run benchmark/headless-render.ts"
  },
  "license": "MIT",
  "author": "Nissan Hanina <nissanhanina@gmail.com>",
  "files": [
    "dist",
    "AGENTS.md"
  ],
  "exports": {
    "./stream": {
      "types": "./dist/types/stream/index.d.ts",
      "import": "./dist/esm/stream/index.js"
    },
    "./stream-extended": {
      "types": "./dist/types/stream-extended/index.d.ts",
      "import": "./dist/esm/stream-extended/index.js"
    },
    "./ui": {
      "types": "./dist/types/ui/index.d.ts",
      "import": "./dist/esm/ui/index.js"
    },
    "./ui-components": {
      "types": "./dist/types/ui-components/index.d.ts",
      "import": "./dist/esm/ui-components/index.js"
    },
    "./ui-components-theme": {
      "types": "./dist/types/ui-components-theme/index.d.ts",
      "import": "./dist/esm/ui-components-theme/index.js"
    },
    "./ui-components-theme-browser": {
      "types": "./dist/types/ui-components-theme-browser/index.d.ts",
      "import": "./dist/esm/ui-components-theme-browser/index.js"
    },
    "./ui-renderer-dom": {
      "types": "./dist/types/ui-renderer-dom/index.d.ts",
      "import": "./dist/esm/ui-renderer-dom/index.js"
    },
    "./takumi": {
      "types": "./dist/types/ui-renderer-takumi/index.d.ts",
      "import": "./dist/esm/ui-renderer-takumi/index.js"
    },
    "./ui-router": {
      "types": "./dist/types/ui-router/index.d.ts",
      "import": "./dist/esm/ui-router/index.js"
    }
  },
  "dependencies": {
    "csstype": "3.2.3"
  },
  "devDependencies": {
    "@most/core": "1.6.1",
    "@most/scheduler": "1.3.0",
    "@takumi-rs/core": "^1.1.2",
    "bun-types": "^1.3.13",
    "tinybench": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
